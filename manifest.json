{
    "manifest_version": 3,
    "name": "Q&A Finder - Tìm Đáp Án",
    "version": "2.2",
    "description": "Tìm đáp án phù hợp nhất cho câu hỏi của bạn từ ngân hàng câu hỏi đã lưu",
    "permissions": [
      "storage",
      "activeTab",
      "contextMenus"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
      }
    },
    "icons": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }